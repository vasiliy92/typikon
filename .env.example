# ── Typikon Environment ──
# Copy to .env and adjust before deploying

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=typikon
POSTGRES_USER=typikon
POSTGRES_PASSWORD=typikon_dev

# Redis
REDIS_URL=redis://redis:6379/0

# Backend
BACKEND_PORT=8000
ADMIN_API_KEY=change-me-in-production
LOG_LEVEL=info

# Frontend
NEXT_PUBLIC_API_URL=/api

# Docker registry (for CI/CD)
DOCKER_REGISTRY=registry.example.com
DOCKER_IMAGE_PREFIX=typikon

# Traefik
TRAEFIK_ENTRYPOINT=web
TRAEFIK_DOMAIN=typikon.example.com
