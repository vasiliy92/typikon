# PostgreSQL
POSTGRES_DB=typikon
POSTGRES_USER=typikon
POSTGRES_PASSWORD=typikon_dev
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# Backend
ADMIN_API_KEY=change-me-in-production
LOG_LEVEL=info
CORS_ORIGINS=*

# Traefik
TRAEFIK_DOMAIN=typikon.localhost
TRAEFIK_ENTRYPOINT=web

# Docker image prefix
DOCKER_IMAGE_PREFIX=typikon
