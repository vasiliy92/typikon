# ──────────────────────────────────────────────
# Typikon — Environment Variables
# ──────────────────────────────────────────────
# In production, these are set by Jenkins via
# credentials() bindings. For local dev, copy
# this file to .env and fill in values.
# ──────────────────────────────────────────────

# Domain (Traefik Host rule)
DOMAIN=typikon.localhost

# Traefik entrypoint
TRAEFIK_ENTRYPOINT=web

# PostgreSQL
POSTGRES_DB=typikon
POSTGRES_USER=typikon
POSTGRES_PASSWORD=typikon_dev
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# Backend
ADMIN_API_KEY=change-me-in-production
SUPERADMIN_EMAIL=admin@typikon.local
SUPERADMIN_PASSWORD=change-me-in-production
LOG_LEVEL=info
CORS_ORIGINS=*

# Frontend
NEXT_PUBLIC_API_URL=

# Docker image tag (set by Jenkins BUILD_NUMBER)
TAG=latest
